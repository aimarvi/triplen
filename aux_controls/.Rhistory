ed_long
# simple glmm fit
fit03 <- glmmTMB(data=ed_long, ED ~ type + major_selectivity + avg_topk_zscore)
summary(fit03)
# interaction between ED change and top-k sampling strength
fit04 <- glmmTMB(data=ed_long, ED ~ type * avg_topk_zscore)
summary(fit04)
# interaction between ED change and top-k sampling strength
# both effects are present: local --> global and sampling strength --> low ED
fit04 <- glmmTMB(data=ed_long, ED ~ type * avg_topk_zscore + major_selectivity)
summary(fit04)
# interaction between ED change and top-k sampling strength
# both effects are present: local --> global and sampling strength --> low ED
fit04 <- glmmTMB(data=ed_long, ED ~ type * avg_topk_zscore * major_selectivity)
summary(fit04)
# interaction between ED change and top-k sampling strength
# both effects are present: local --> global and sampling strength --> low ED
